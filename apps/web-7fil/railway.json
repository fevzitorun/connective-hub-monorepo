{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd ../.. && pnpm install --frozen-lockfile --ignore-scripts && pnpm turbo build --filter=@7fil/web"
  },
  "deploy": {
    "startCommand": "node apps/web-7fil/.next/standalone/apps/web-7fil/server.js",
    "healthcheckPath": "/",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
